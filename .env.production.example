# =============================================================================
# AI Employee OS — Production Environment (EXAMPLE ONLY)
# Copy to .env.production and fill real secrets. Never commit secrets.
# =============================================================================

# --- Application ---
APP_ENV=production
APP_DEBUG=false
APP_SECRET_KEY=replace-with-long-random-secret

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
UVICORN_WORKERS=2
# Prefer one-shot migrate for scaled API:
#   docker compose -f docker-compose.prod.yml --env-file .env.production \
#     run --rm backend python /app/docker/migrate_with_lock.py
# Single replica may use true (entrypoint holds Postgres advisory lock).
RUN_MIGRATIONS_ON_STARTUP=false

# --- PostgreSQL ---
POSTGRES_DB=ai_employee_os
POSTGRES_USER=ai_employee
POSTGRES_PASSWORD=replace-with-strong-password
DATABASE_URL=postgresql+asyncpg://ai_employee:replace-with-strong-password@postgres:5432/ai_employee_os
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# --- Redis (AUTH required in prod compose) ---
REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_URL=redis://:replace-with-strong-redis-password@redis:6379/0

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
# If set, compose also sets QDRANT__SERVICE__API_KEY — values must match.
QDRANT_API_KEY=replace-with-qdrant-api-key
QDRANT_COLLECTION=knowledge

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=replace-minio-access-key
MINIO_SECRET_KEY=replace-minio-secret-key
# Edge TLS terminates outside the docker network; leave false inside compose.
MINIO_SECURE=false
MINIO_BUCKET=artifacts

# --- LLM Gateway (OpenRouter) ---
OPENROUTER_API_KEY=replace-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_LLM_MODEL=deepseek/deepseek-chat
FALLBACK_LLM_MODEL=anthropic/claude-sonnet-4
SECONDARY_FALLBACK_LLM_MODEL=openai/gpt-4o-mini

# --- Telegram (NOVA) — separate worker service in prod compose ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=true
TELEGRAM_INLINE_POLLING=false
AGENT_NAME=NOVA
UVICORN_WORKERS=1

# --- Security ---
SECURITY_ENABLED=true
SECURITY_RATE_LIMIT=120
SECURITY_RATE_WINDOW_SECONDS=60

# --- Agency archive (host path mounted read-only into /data/agency_archive) ---
AGENCY_ARCHIVE_PATH=/home/admin/business-assistant/user_data/clients
MEMORY_ENABLED=true
SKILLS_ENABLED=true
REDIS_MEMORY_TTL=3600

# --- Observability ---
LOG_LEVEL=INFO
SENTRY_DSN=
