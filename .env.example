# =============================================================================
# AI Employee OS — Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_employee_os
POSTGRES_USER=ai_employee
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis (Session Memory) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# --- Qdrant (Knowledge Memory) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_KNOWLEDGE=knowledge
QDRANT_COLLECTION_CLIENT=client_memory

# --- LLM Gateway (OpenRouter) ---
OPENROUTER_API_KEY=change-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_DEFAULT_MODEL=anthropic/claude-sonnet-4
LLM_FAST_MODEL=openai/gpt-4o-mini
LLM_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Mem0 (Long Term Memory) ---
MEM0_API_KEY=
MEM0_USER_ID=ai-employee-os

# --- Whisper (Audio Transcription) ---
WHISPER_MODEL=whisper-1
WHISPER_API_KEY=

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=change-me

# --- Observability ---
LOG_LEVEL=INFO
TRACE_ENABLED=true
SENTRY_DSN=

# --- Artifact Storage ---
ARTIFACT_STORAGE_PATH=./artifacts
ARTIFACT_MAX_VERSIONS=10

# --- Human Approval ---
APPROVAL_REQUIRED_FOR_COMPLEX_TASKS=true
APPROVAL_TIMEOUT_MINUTES=60
