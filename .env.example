# =============================================================================
# AI Employee OS — Environment Configuration
# Copy this file to .env and fill in the values.
# =============================================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change-me-to-a-random-secret

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=ai_employee_os
POSTGRES_USER=ai_employee
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+asyncpg://ai_employee:change-me@localhost:5433/ai_employee_os

# --- Redis (Session Memory) ---
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_DB=0
# Leave REDIS_PASSWORD empty for local open Redis (compose skips --requirepass).
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6380/0
# With password: REDIS_URL=redis://:your-password@localhost:6380/0

# --- Qdrant (Knowledge Memory / Vector DB) ---
QDRANT_HOST=localhost
QDRANT_PORT=6335
QDRANT_URL=http://localhost:6335
# Optional. If set, must match Qdrant QDRANT__SERVICE__API_KEY (compose wires both).
QDRANT_API_KEY=
QDRANT_COLLECTION_KNOWLEDGE=knowledge
QDRANT_COLLECTION_CLIENT=client_memory

# --- MinIO (Object Storage: documents, images, audio, artifacts) ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# Inside docker network TLS is off; terminate TLS at the edge/reverse-proxy.
MINIO_SECURE=false
MINIO_BUCKET=artifacts
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- LLM Gateway (OpenRouter) ---
OPENROUTER_API_KEY=change-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_LLM_MODEL=deepseek/deepseek-chat
FALLBACK_LLM_MODEL=anthropic/claude-sonnet-4
SECONDARY_FALLBACK_LLM_MODEL=openai/gpt-4o-mini

# --- Mem0 (Long Term Memory) — Stage 3+ ---
MEM0_API_KEY=
MEM0_USER_ID=ai-employee-os

# --- Whisper (Audio Transcription) — Stage 6+ ---
WHISPER_MODEL=whisper-1
WHISPER_API_KEY=

# --- Telegram Bot — Stage 21 ---
TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_ENABLED=false
# Dev: inline polling in API process (default True). Prod separate worker: False.
TELEGRAM_INLINE_POLLING=true
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=change-me

# --- Database pool ---
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
RUN_MIGRATIONS_ON_STARTUP=false

# --- Security — Stage 23 ---
SECURITY_ENABLED=false
SECURITY_RATE_LIMIT=120
SECURITY_RATE_WINDOW_SECONDS=60

# --- Observability ---
LOG_LEVEL=INFO
TRACE_ENABLED=true
# Leave empty in tests/dev — Sentry only initializes when set.
SENTRY_DSN=

# --- Memory System ---
MEMORY_ENABLED=true
REDIS_MEMORY_TTL=3600
QDRANT_COLLECTION=knowledge

# --- Skills ---
SKILLS_ENABLED=true

# --- Research (Perplexity Sonar via OpenRouter) ---
# Keep RESEARCH_ENABLED=false until OPENROUTER_API_KEY is real.
# Then: RESEARCH_ENABLED=true and RESEARCH_PROVIDER=sonar
RESEARCH_ENABLED=false
RESEARCH_PROVIDER=none
RESEARCH_SONAR_MODEL=perplexity/sonar
RESEARCH_ALLOW_MOCK=false
SEMANTIC_MEMORY_ENABLED=false
EMBEDDING_ALLOW_STUB=false

# --- Artifact Storage ---
ARTIFACT_STORAGE_PATH=./artifacts
ARTIFACT_MAX_VERSIONS=10

# --- Human Approval — Stage 4+ ---
APPROVAL_REQUIRED_FOR_COMPLEX_TASKS=true
APPROVAL_TIMEOUT_MINUTES=60

# Agency identity (injected into dialogue + documents)
AGENCY_NAME=NOVA
AGENCY_TAGLINE=
AGENCY_POSITIONING=
AGENCY_SERVICES=
AGENCY_TONE=
AGENCY_REQUISITES=
AGENCY_CONTACTS=
AGENCY_WEBSITE=
AGENCY_PROFILE_JSON=
